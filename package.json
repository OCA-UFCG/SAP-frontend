{
  "name": "sap-frontend-app",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.8.0",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "prebuild": "npm run generate:municipal-availability",
    "generate:municipal-availability": "node tools/drive-contentful-pipeline/generate-municipal-availability-index.mjs",
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "pipeline:drive-csv-json": "node --max-old-space-size=4096 tools/drive-contentful-pipeline/drive-csv-to-json.mjs",
    "pipeline:contentful-panel-layer": "node --max-old-space-size=4096 tools/drive-contentful-pipeline/contentful-update-panel-layer-image-data.mjs",
    "pipeline:contentful-panel-layer:dry-run-all": "node --max-old-space-size=4096 tools/drive-contentful-pipeline/contentful-update-panel-layer-image-data.mjs --all-panel-layers --dry-run",
    "pipeline:contentful-panel-layer:publish-all": "node --max-old-space-size=4096 tools/drive-contentful-pipeline/contentful-update-panel-layer-image-data.mjs --all-panel-layers --publish",
    "pipeline:contentful-municipal-analysis": "node --max-old-space-size=4096 tools/drive-contentful-pipeline/contentful-update-municipal-analysis.mjs",
    "pipeline:contentful-municipal-analysis:dry-run-all": "node --max-old-space-size=4096 tools/drive-contentful-pipeline/contentful-update-municipal-analysis.mjs --sync-partitions --all-panel-layers --dry-run",
    "pipeline:contentful-municipal-analysis:publish-all": "node --max-old-space-size=4096 tools/drive-contentful-pipeline/contentful-update-municipal-analysis.mjs --sync-partitions --all-panel-layers --publish",
    "pipeline:full-cycle": "node --max-old-space-size=4096 tools/drive-contentful-pipeline/pipeline-full-cycle.mjs",
    "pipeline:verify": "node --max-old-space-size=4096 tools/drive-contentful-pipeline/pipeline-verify.mjs",
    "ci:verify": "npm run lint && npm run test:unit -- --run && npm run build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "husky",
    "test": "vitest",
    "test:unit": "vitest --project unit",
    "test:storybook": "vitest --project storybook",
    "precommit": "lint-staged --no-stash",
    "format": "prettier --write ."
  },
  "overrides": {
    "minimatch": "^10.2.1"
  },
  "dependencies": {
    "@amcharts/amcharts5": "^5.17.2",
    "@contentful/rich-text-react-renderer": "^16.1.6",
    "@contentful/rich-text-types": "^17.2.7",
    "@google/earthengine": "^1.7.21",
    "@turf/turf": "^7.3.4",
    "amcharts": "^3.14.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "contentful": "^11.12.0",
    "firebase": "^12.13.0",
    "firebase-admin": "^13.10.0",
    "internmap": "^2.0.3",
    "leaflet": "^1.9.4",
    "leaflet-defaulticon-compatibility": "^0.1.2",
    "lru-cache": "^11.5.2",
    "maplibre-gl": "^5.22.0",
    "next": "^16.1.6",
    "next-intl": "^4.13.0",
    "postcss": "^8.5.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.75.0",
    "react-leaflet": "^5.0.0-rc.2",
    "recharts": "^3.7.0",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.0",
    "@storybook/addon-a11y": "^10.2.7",
    "@storybook/addon-docs": "^10.2.7",
    "@storybook/addon-styling-webpack": "^3.0.0",
    "@storybook/addon-vitest": "^10.2.7",
    "@storybook/nextjs": "^10.2.8",
    "@storybook/nextjs-vite": "^10.2.7",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.3",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.24",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-storybook": "^10.2.7",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^16.2.7",
    "playwright": "^1.58.2",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "storybook": "^10.2.7",
    "tailwindcss": "^4.2.4",
    "typescript": "^6",
    "vite": "^8.0.10",
    "vite-tsconfig-paths": "^6.0.5",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "*.{json,md,css,scss,yml,yaml}": [
      "prettier --write"
    ]
  }
}
